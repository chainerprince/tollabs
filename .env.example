# ──────────────────────────────────────────────
#  TOLLABS — Environment Configuration
# ──────────────────────────────────────────────
#  Copy this file:  cp .env.example .env
#  Then fill in the values below.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=sqlite:///./tollabs.db

# ── Security ──────────────────────────────────
SECRET_KEY=change-me-in-production

# ── AI — Google Gemini ────────────────────────
#  Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── HuggingFace (model training) ─────────────
#  Get a token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your-huggingface-token-here

# ── Mock Mode ─────────────────────────────────
#  USE_MOCK_STRIPE=True  — wallet/payments always mocked
#  USE_MOCK_MODAL=True   — cloud notebook execution mocked
#  USE_MOCK_TRAINING=False — REAL Modal GPU training (requires Modal credits)
#  USE_MOCK_TRADING=False  — REAL deployed model inference for trades
USE_MOCK_STRIPE=True
USE_MOCK_TRADING=False
USE_MOCK_MODAL=True
USE_MOCK_TRAINING=False

# ── Modal (required for real GPU training & inference) ──
#  Get these from: https://modal.com/settings#tokens
#  On Render/Railway, set these as env vars — no interactive login needed.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
