# ──────────────────────────────────────────────
#  TOLLABS — Environment Configuration
# ──────────────────────────────────────────────
#  Copy this file:  cp .env.example .env
#  Then fill in the values below.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=sqlite:///./tollabs.db

# ── Security ──────────────────────────────────
SECRET_KEY=change-me-in-production

# ── AI — Google Gemini ────────────────────────
#  Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── HuggingFace (model training) ─────────────
#  Get a token: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your-huggingface-token-here

# ── Mock Mode ─────────────────────────────────
#  Set all to True for hackathon demo (no real money / GPUs)
USE_MOCK_STRIPE=True
USE_MOCK_TRADING=True
USE_MOCK_MODAL=True
USE_MOCK_TRAINING=True

# ── Modal (optional, for real GPU training) ───
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
